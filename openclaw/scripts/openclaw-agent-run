#!/usr/bin/with-contenv bash
set -euo pipefail

umask 0002

AGENT_USER="abc"
AGENT_BIN="/usr/local/bin/openclaw-agent"
PERSISTENT_DIR="${CLAWMANAGER_AGENT_PERSISTENT_DIR:-/config}"
AGENT_DATA_DIR="${OPENCLAW_AGENT_DATA_DIR:-$PERSISTENT_DIR/openclaw-agent}"
AGENT_LOG_DIR="/var/log/openclaw-agent"
AGENT_CONFIG_DIR="/etc/openclaw-agent"
AGENT_CONFIG_FILE="$AGENT_CONFIG_DIR/config.yaml"

export CLAWMANAGER_AGENT_PERSISTENT_DIR="$PERSISTENT_DIR"
export OPENCLAW_AGENT_DATA_DIR="$AGENT_DATA_DIR"

repair_team_shared_dir() {
  local team_dir="${CLAWMANAGER_TEAM_SHARED_DIR:-/team}"
  if [[ "$(id -u)" != "0" || ! -d "$team_dir" ]]; then
    return 0
  fi
  chown -R 1000:1000 "$team_dir" || true
  chmod -R ug+rwX "$team_dir" || true
  find "$team_dir" -type d -exec chmod g+s {} \; || true
}

mkdir -p "$AGENT_DATA_DIR" "$AGENT_LOG_DIR" "$AGENT_CONFIG_DIR"
repair_team_shared_dir

if [ ! -f "$AGENT_CONFIG_FILE" ]; then
  cp /defaults/openclaw-agent/config.yaml "$AGENT_CONFIG_FILE"
fi

chown -R "$AGENT_USER:$AGENT_USER" "$AGENT_DATA_DIR" "$AGENT_LOG_DIR" "$AGENT_CONFIG_DIR"
chmod 0755 "$AGENT_DATA_DIR" "$AGENT_LOG_DIR" "$AGENT_CONFIG_DIR"
chmod 0644 "$AGENT_CONFIG_FILE"

exec "$AGENT_BIN"
