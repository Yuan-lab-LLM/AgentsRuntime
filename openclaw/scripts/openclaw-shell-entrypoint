#!/bin/sh
set -eu

umask 0002

AGENT_USER="${OPENCLAW_AGENT_DROP_USER_NAME:-abc}"
AGENT_BIN="/usr/local/bin/openclaw-agent"
PERSISTENT_DIR="${CLAWMANAGER_AGENT_PERSISTENT_DIR:-/config}"
AGENT_DATA_DIR="${OPENCLAW_AGENT_DATA_DIR:-$PERSISTENT_DIR/openclaw-shell-agent}"
AGENT_LOG_DIR="${AGENT_DATA_DIR}/logs"
AGENT_CONFIG_DIR="/etc/openclaw-agent"
AGENT_CONFIG_FILE="${OPENCLAW_AGENT_CONFIG_PATH:-$AGENT_CONFIG_DIR/config.yaml}"
DEFAULT_CONFIG="/defaults/openclaw-shell-agent/config.yaml"

export CLAWMANAGER_AGENT_PERSISTENT_DIR="$PERSISTENT_DIR"
export OPENCLAW_AGENT_DATA_DIR="$AGENT_DATA_DIR"
export OPENCLAW_AGENT_CONFIG_PATH="$AGENT_CONFIG_FILE"
export OPENCLAW_AGENT_RUNTIME_TYPE="${OPENCLAW_AGENT_RUNTIME_TYPE:-openclaw-shell}"
export OPENCLAW_AGENT_RUNTIME_NAME="${OPENCLAW_AGENT_RUNTIME_NAME:-OpenClaw Shell}"
export OPENCLAW_AGENT_DESKTOP_BASE="${OPENCLAW_AGENT_DESKTOP_BASE:-none}"
export OPENCLAW_AGENT_RUNTIME_PORT="${OPENCLAW_AGENT_RUNTIME_PORT:-18789}"
export OPENCLAW_AGENT_BROWSER_AUTO_LAUNCH_ENABLED="${OPENCLAW_AGENT_BROWSER_AUTO_LAUNCH_ENABLED:-false}"
case "${TERM:-}" in
  ""|dumb|unknown) export TERM=xterm-256color ;;
esac
export COLORTERM="${COLORTERM:-truecolor}"
export FORCE_COLOR="${FORCE_COLOR:-1}"
export CLICOLOR="${CLICOLOR:-1}"
export CLICOLOR_FORCE="${CLICOLOR_FORCE:-1}"
export NPM_CONFIG_COLOR="${NPM_CONFIG_COLOR:-always}"
export YARN_FORCE_COLOR="${YARN_FORCE_COLOR:-1}"
unset NO_COLOR
export HOME="${HOME:-/config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/config/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-/config/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-/config/.local/share}"
export NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-/config/.cache/npm}"
export OPENCLAW_SHELL_WORKDIR="${OPENCLAW_SHELL_WORKDIR:-/team}"

repair_team_shared_dir() {
  team_dir="${CLAWMANAGER_TEAM_SHARED_DIR:-/team}"
  if [ "$(id -u)" != "0" ] || [ ! -d "$team_dir" ]; then
    return 0
  fi
  chown -R 1000:1000 "$team_dir" || true
  chmod -R ug+rwX "$team_dir" || true
  find "$team_dir" -type d -exec chmod g+s {} \; || true
}

mkdir -p \
  "$PERSISTENT_DIR" \
  "$AGENT_DATA_DIR" \
  "$AGENT_LOG_DIR" \
  "$AGENT_DATA_DIR/history" \
  "$AGENT_CONFIG_DIR" \
  "$HOME" \
  "$XDG_CACHE_HOME" \
  "$XDG_CONFIG_HOME" \
  "$XDG_DATA_HOME" \
  "$NPM_CONFIG_CACHE" \
  /config/.openclaw/workspace/skills \
  /config/.openclaw/extensions

repair_team_shared_dir

if [ ! -f "$AGENT_CONFIG_FILE" ]; then
  cp "$DEFAULT_CONFIG" "$AGENT_CONFIG_FILE"
fi

if [ "$(id -u)" = "0" ] && id "$AGENT_USER" >/dev/null 2>&1; then
  AGENT_GROUP="$(id -gn "$AGENT_USER")"
  chown -R "$AGENT_USER:$AGENT_GROUP" \
    "$PERSISTENT_DIR" \
    "$AGENT_DATA_DIR" \
    "$AGENT_LOG_DIR" \
    "$AGENT_CONFIG_DIR" \
    "$HOME" \
    "$XDG_CACHE_HOME" \
    "$XDG_CONFIG_HOME" \
    "$XDG_DATA_HOME" \
    /config/.openclaw || true
fi

exec "$AGENT_BIN"
