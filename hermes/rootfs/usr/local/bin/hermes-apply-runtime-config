#!/usr/bin/env bash
set -euo pipefail

export HOME="${HOME:-/config}"
export HERMES_HOME="${HERMES_HOME:-/config/.hermes}"

mkdir -p "${HERMES_HOME}"

python_bin="/usr/local/lib/hermes-agent/venv/bin/python"
if [ ! -x "${python_bin}" ]; then
    python_bin="$(command -v python3 || command -v python)"
fi

"${python_bin}" <<'PY'
import os
import json
import hashlib
import re
import shutil
from pathlib import Path
from datetime import datetime, timezone
from urllib.parse import urlparse

import yaml


def first_env(*names):
    for name in names:
        value = os.environ.get(name, "")
        if value and value.strip():
            return name, value.strip()
    return "", ""


BOOTSTRAP_ENV_NAMES = {
    "manifest": (
        "CLAWMANAGER_HERMES_BOOTSTRAP_MANIFEST_JSON",
        "CLAWMANAGER_RUNTIME_BOOTSTRAP_MANIFEST_JSON",
        "CLAWMANAGER_OPENCLAW_BOOTSTRAP_MANIFEST_JSON",
    ),
    "channels": (
        "CLAWMANAGER_HERMES_CHANNELS_JSON",
        "CLAWMANAGER_RUNTIME_CHANNELS_JSON",
        "CLAWMANAGER_OPENCLAW_CHANNELS_JSON",
    ),
    "skills": (
        "CLAWMANAGER_HERMES_SKILLS_JSON",
        "CLAWMANAGER_RUNTIME_SKILLS_JSON",
        "CLAWMANAGER_OPENCLAW_SKILLS_JSON",
    ),
}


def unique_nonempty(values):
    result = []
    seen = set()
    for value in values:
        item = str(value or "").strip()
        if not item:
            continue
        key = item.lower()
        if key in seen:
            continue
        result.append(item)
        seen.add(key)
    return result


def parse_models(value):
    raw = (value or "").strip()
    if not raw:
        return []

    parsed = None
    json_raw = raw.replace('\\"', '"')
    if json_raw[0] in "[{":
        try:
            parsed = json.loads(json_raw)
        except Exception:
            parsed = None

    if isinstance(parsed, list):
        values = []
        for item in parsed:
            if isinstance(item, str):
                values.append(item)
            elif isinstance(item, dict):
                for key in ("model", "default", "name", "id"):
                    if item.get(key):
                        values.append(item[key])
                        break
        return unique_nonempty(values)

    if isinstance(parsed, dict):
        values = []
        models = parsed.get("models")
        if isinstance(models, list):
            values.extend(models)
        elif isinstance(models, dict):
            values.extend(models.keys())
        for key in ("model", "default", "name", "id"):
            value = str(parsed.get(key, "")).strip()
            if value:
                values.append(value)
        return unique_nonempty(values)

    if raw.startswith("[") and raw.endswith("]"):
        values = [
            item.strip().strip("\"'")
            for item in raw[1:-1].split(",")
            if item.strip().strip("\"'")
        ]
        return unique_nonempty(values)

    if "," in raw:
        return unique_nonempty(raw.split(","))

    return [raw]


def parse_jsonish(value):
    raw = (value or "").strip()
    if not raw:
        return None

    json_raw = raw.replace('\\"', '"')
    try:
        return json.loads(json_raw)
    except Exception:
        pass

    if raw[0] in "[{":
        try:
            return yaml.safe_load(raw)
        except Exception:
            return None

    return None


def parse_env_json(*names):
    name, value = first_env(*names)
    if not value:
        return "", None
    parsed = parse_jsonish(value)
    return name, parsed if parsed is not None else value


def read_priority_json(kind, *extra_names):
    names = (*BOOTSTRAP_ENV_NAMES.get(kind, ()), *extra_names)
    source, raw = first_env(*names)
    if not raw:
        return {
            "kind": kind,
            "source_env": "",
            "raw_sha256": "",
            "parsed": None,
            "error": "",
        }
    parsed = parse_jsonish(raw)
    error = "" if parsed is not None else f"{source} contains invalid JSON"
    return {
        "kind": kind,
        "source_env": source,
        "raw_sha256": hashlib.sha256(raw.encode("utf-8")).hexdigest(),
        "parsed": parsed,
        "error": error,
    }


def utc_now():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def write_json_secure(path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    tmp.replace(path)
    path.chmod(0o600)


def bootstrap_dir(hermes_home):
    return hermes_home / "hermes-agent" / "bootstrap"


def persist_bootstrap_payload(hermes_home, name, payload):
    write_json_secure(bootstrap_dir(hermes_home) / f"{name}.json", payload)


def safe_key(value, fallback="item"):
    raw = str(value or "").strip().lower()
    raw = re.sub(r"[^a-z0-9_.-]+", "-", raw)
    raw = raw.strip(".-")
    return raw or fallback


def parse_list_value(value, path_mode=False):
    if value is None:
        return []

    if isinstance(value, (list, tuple, set)):
        items = []
        for item in value:
            if isinstance(item, dict):
                for key in ("path", "dir", "directory", "name", "id", "value"):
                    if item.get(key):
                        items.append(item[key])
                        break
            else:
                items.append(item)
        return unique_nonempty(items)

    if isinstance(value, dict):
        for key in ("external_dirs", "dirs", "directories", "paths", "items", "values", "skills"):
            if key in value:
                return parse_list_value(value.get(key), path_mode=path_mode)
        return unique_nonempty(value.keys())

    raw = str(value or "").strip()
    if not raw:
        return []

    parsed = parse_jsonish(raw)
    if parsed is not None and parsed is not value:
        return parse_list_value(parsed, path_mode=path_mode)

    if raw.startswith("[") and raw.endswith("]"):
        return unique_nonempty(
            item.strip().strip("\"'")
            for item in raw[1:-1].split(",")
        )

    separators = [",", ";"]
    if path_mode:
        separators.append(":")

    values = [raw]
    for separator in separators:
        if separator in raw:
            values = raw.split(separator)
            break

    return unique_nonempty(values)


def env_value(value):
    if value is None:
        return ""
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (list, tuple, set)):
        return ",".join(str(item).strip() for item in value if str(item).strip())
    if isinstance(value, dict):
        return json.dumps(value, ensure_ascii=False, separators=(",", ":"))
    return str(value).strip()


def parse_bool(value):
    if isinstance(value, bool):
        return value
    raw = str(value or "").strip().lower()
    if raw in {"1", "true", "yes", "y", "on", "enabled"}:
        return True
    if raw in {"0", "false", "no", "n", "off", "disabled"}:
        return False
    return None


def truthy_env(name):
    return parse_bool(os.environ.get(name, "")) is True


def parse_int(value):
    try:
        return int(str(value).strip())
    except Exception:
        return None


def first_field(mapping, *names):
    if not isinstance(mapping, dict):
        return None
    for name in names:
        if name in mapping and mapping[name] not in (None, ""):
            return mapping[name]
    return None


def deep_merge(base, extra):
    if not isinstance(base, dict):
        base = {}
    if not isinstance(extra, dict):
        return base
    for key, value in extra.items():
        if isinstance(value, dict) and isinstance(base.get(key), dict):
            base[key] = deep_merge(base[key], value)
        else:
            base[key] = value
    return base


def normalize_platform(value):
    raw = str(value or "").strip().lower().replace("-", "_")
    for suffix in ("_connector", "_channel", "_bot", "_adapter", "_gateway"):
        if raw.endswith(suffix):
            raw = raw[: -len(suffix)]
    aliases = {
        "lark": "feishu",
        "feishu_connector": "feishu",
        "dingtalk_connector": "dingtalk",
        "wechat": "weixin",
        "weixin": "weixin",
        "wecom": "wecom",
        "wecom_callback": "wecom_callback",
        "enterprise_wechat": "wecom",
        "qq": "qqbot",
        "qq_bot": "qqbot",
        "qqbot": "qqbot",
        "home_assistant": "homeassistant",
        "ha": "homeassistant",
        "api": "api_server",
        "api_server": "api_server",
        "blue_bubbles": "bluebubbles",
    }
    if raw in aliases:
        return aliases[raw]
    for platform in (
        "telegram",
        "discord",
        "slack",
        "whatsapp",
        "signal",
        "mattermost",
        "matrix",
        "dingtalk",
        "feishu",
        "wecom_callback",
        "wecom",
        "weixin",
        "qqbot",
        "yuanbao",
        "bluebubbles",
        "api_server",
        "webhook",
    ):
        if raw == platform or raw.startswith(platform + "_"):
            return platform
    return raw


